# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/

# Data: 原本・前処理済みはコミットしない（README と .gitkeep のみ管理）
data/**/raw/*
data/**/processed/*
data/**/climatology/*
!data/**/raw/.gitkeep
!data/**/processed/.gitkeep
!data/**/climatology/.gitkeep

# IDE / Editor
.vscode/
.idea/
*.swp

# Claude Code local settings (per-user, not for the repo)
.claude/

# OS
.DS_Store
Thumbs.db

# Notebook 実行出力（必要に応じて）
# *.ipynb

# 生成画像はコミットしない（スクリプトで再生成可能）
figures/**/*.png
figures/*.png

# 参考文献の PDF はコミットしない（著作権・容量。出典は docs/*.md に記載）
docs/**/*.pdf
docs/*.pdf
*.pdf
# Dropbox が付与するサイドカー属性ファイル
*:com.dropbox.attrs
