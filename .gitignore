# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# Virtual environments
.venv/
venv/
env/

# Data: do not commit raw/processed files (track only README and .gitkeep)
data/**/raw/*
data/**/processed/*
data/**/climatology/*
!data/**/raw/.gitkeep
!data/**/processed/.gitkeep
!data/**/climatology/.gitkeep

# IDE / Editor
.vscode/
.idea/
*.swp

# Claude Code local settings (per-user, not for the repo)
.claude/

# OS
.DS_Store
Thumbs.db

# Notebook execution outputs (uncomment if needed)
# *.ipynb

# Generated figures are not committed (regenerable by scripts)
figures/**/*.png
figures/*.png
# Intermediate data from --save-field etc. (large, regenerable; e.g. field_Chla[_lowsal].npz)
figures/**/*.npz
figures/*.npz

# docs/*.md are personal notes: keep out of the public repo (also purged from history)
docs/*.md
docs/**/*.md
# Reference PDFs are not committed (copyright / size)
docs/**/*.pdf
docs/*.pdf
*.pdf
# Dropbox sidecar attribute files
*:com.dropbox.attrs

# CMEMS credentials (never commit)
cmems.env
**/cmems.env

# CLAUDE.md is a personal dev-guide note; keep out of the public repo
CLAUDE.md

# Backup for trial/rejected models (publish only confirmed models; trials are regenerable, not committed)
models/pretrained/backup/

# Exported weight dumps for the Fortran/portable inference path (regenerable by porting/export_weights.py)
porting/exported/
