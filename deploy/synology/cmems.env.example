# Copernicus Marine credentials for the cmems-mirror container.
# Copy to cmems.env (NOT committed; keep it readable only by you) and fill in.
#   cp cmems.env.example cmems.env && chmod 600 cmems.env
COPERNICUSMARINE_SERVICE_USERNAME=your_copernicus_username
COPERNICUSMARINE_SERVICE_PASSWORD=your_copernicus_password

# Optional overrides (defaults shown):
# DATASET_ID=cmems_obs-oc_glo_bgc-plankton_my_l4-gapfree-multi-4km_P1D
# DATASET_VERSION=202603
# OUTDIR=/data/gapfree_daily

# Proxy (REQUIRED behind a campus/corporate proxy): copernicusmarine downloads
# go through these at run time. Use the same host:port set in DSM network proxy.
# HTTP_PROXY=http://PROXY_HOST:PORT
# HTTPS_PROXY=http://PROXY_HOST:PORT
# NO_PROXY=localhost,127.0.0.1
